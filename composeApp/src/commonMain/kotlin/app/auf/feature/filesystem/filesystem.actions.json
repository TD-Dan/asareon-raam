{
  "feature_name": "filesystem",
  "summary": "Acts as the sole, transactional, and secure gateway to the file system.",
  "permissions": ["read", "write", "delete", "workspace", "system-files", "ui"],
  "actions": [
    {
      "action_name": "filesystem.LIST",
      "summary": "List files and directories in callers own private sandbox.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "An optional sub-directory within the sandbox to list.",
            "default": ""
          },
          "recursive": {
            "type": "boolean",
            "default": false
          },
          "correlationId": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional correlation ID passed through to the response envelope.",
            "default": null
          }
        }
      },
      "agent_exposure": {
        "requires_approval": false,
        "sandbox_rule": {
          "strategy": "AGENT_WORKSPACE",
          "path_prefix_template": "{agentId}/workspace"
        }
      },
      "required_permissions": ["read", "workspace"]
    },
    {
      "action_name": "filesystem.SYSTEM_READ",
      "summary": "A sandboxed service action for other features to read a file from their private sandbox. The response is delivered via the private channel.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      },
      "agent_exposure": {
        "requires_approval": false,
        "sandbox_rule": {
          "strategy": "AGENT_WORKSPACE",
          "path_prefix_template": "{agentId}/workspace"
        }
      },
      "required_permissions": ["read", "workspace"]
    },
    {
      "action_name": "filesystem.SYSTEM_WRITE",
      "summary": "A sandboxed service action for other features to write a file to their private sandbox.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "encrypt": {
            "type": "boolean",
            "description": "If true, the content will be encrypted at rest. Defaults to false.",
            "default": false
          }
        },
        "required": [
          "path",
          "content"
        ]
      },
      "agent_exposure": {
        "requires_approval": false,
        "sandbox_rule": {
          "strategy": "AGENT_WORKSPACE",
          "path_prefix_template": "{agentId}/workspace",
          "payload_rewrites": {
            "encrypt": "False"
          }
        }
      }
    },
    {
      "action_name": "filesystem.SYSTEM_DELETE",
      "summary": "A sandboxed service action for other features to delete a file from their private sandbox.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      },
      "agent_exposure": {
        "requires_approval": false,
        "sandbox_rule": {
          "strategy": "AGENT_WORKSPACE",
          "path_prefix_template": "{agentId}/workspace"
        }
      }
    },
    {
      "action_name": "filesystem.SYSTEM_DELETE_DIRECTORY",
      "summary": "A sandboxed service action for other features to recursively delete a directory from their private sandbox.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      },
      "agent_exposure": {
        "requires_approval": false,
        "sandbox_rule": {
          "strategy": "AGENT_WORKSPACE",
          "path_prefix_template": "{agentId}/workspace"
        }
      }
    },
    {
      "action_name": "filesystem.REQUEST_SCOPED_READ_UI",
      "summary": "Orchestrates a user-mediated, one-time read of a directory outside the originator's sandbox.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": [
              "string",
              "null"
            ]
          },
          "recursive": {
            "type": "boolean",
            "default": true
          },
          "fileExtensions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional list of extensions to filter by (e.g., [\"json\", \"md\"])"
          }
        }
      },
      "required_permissions": ["read", "system-files", "ui"]
    },
    {
      "action_name": "filesystem.READ_FILES_CONTENT",
      "summary": "A sandboxed service action for other features to request the content of multiple files at once.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "paths"
        ]
      }
    },
    {
      "action_name": "filesystem.OPEN_WORKSPACE_FOLDER",
      "summary": "Open the sandboxed workspace in the native OS file explorer.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "An optional sub-directory within the sandboxed workspace.",
            "default": ""
          }
        }
      },
      "required_permissions": ["read", "workspace", "ui"]
    },
    {
      "action_name": "filesystem.NAVIGATE",
      "summary": "Requests to change the currently viewed directory path.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      },
      "required_permissions": ["write", "ui"]
    },
    {
      "action_name": "filesystem.SELECT_DIRECTORY_UI",
      "summary": "Triggers the native OS file chooser to select a directory.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "required_permissions": ["read", "system-files", "ui"]
    },
    {
      "action_name": "filesystem.EXPAND_ALL",
      "summary": "Recursively expands a directory in the tree view to a safe depth.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.COLLAPSE_ALL",
      "summary": "Recursively collapses a directory and all its children in the tree view.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.ADD_WHITELIST_PATH",
      "summary": "Adds a new directory path to the security whitelist.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.REMOVE_WHITELIST_PATH",
      "summary": "Removes a directory path from the security whitelist.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.ADD_FAVORITE_PATH",
      "summary": "Adds a new directory path to the user's favorites.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.REMOVE_FAVORITE_PATH",
      "summary": "Removes a directory path from the user's favorites.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.TOGGLE_ITEM_EXPANDED",
      "summary": "Toggles the expanded/collapsed state of a directory in the tree view.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.TOGGLE_ITEM_SELECTED",
      "summary": "Toggles the selected/deselected state of a file or directory.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "recursive": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.COPY_SELECTION_TO_CLIPBOARD",
      "summary": "Initiates the process of reading selected files and copying their formatted content to the clipboard.",
      "public": true,
      "broadcast": true,
      "targeted": false
    },
    {
      "action_name": "filesystem.LOAD_CHILDREN",
      "summary": "[INTERNAL] Triggers a side-effect to load a directory's children from disk.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.DIRECTORY_LOADED",
      "summary": "[INTERNAL] Dispatched after a directory's children have been read from disk. Used to update the UI.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "parentPath": {
            "type": "string"
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/FileEntry"
            }
          }
        },
        "required": [
          "parentPath",
          "children"
        ]
      }
    },
    {
      "action_name": "filesystem.EXECUTE_SCOPED_READ",
      "summary": "[INTERNAL] Triggers the side-effect of showing the OS file picker after the user has confirmed the 'Danger Zone' prompt.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "clientOriginator": {
            "type": "string",
            "description": "The original feature that requested the scoped read."
          },
          "requestPayload": {
            "type": "object",
            "description": "The payload of the original REQUEST_SCOPED_READ_UI action."
          }
        },
        "required": [
          "clientOriginator",
          "requestPayload"
        ]
      }
    },
    {
      "action_name": "filesystem.STAGE_SCOPED_READ",
      "summary": "[INTERNAL] Stores the details of a pending scoped read request while awaiting user confirmation.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string"
          },
          "originator": {
            "type": "string"
          },
          "requestPayload": {
            "type": "object"
          }
        },
        "required": [
          "requestId",
          "originator",
          "requestPayload"
        ]
      }
    },
    {
      "action_name": "filesystem.FINALIZE_SCOPED_READ",
      "summary": "[INTERNAL] Clears the pending scoped read request from the state after the workflow is complete.",
      "public": false,
      "broadcast": false,
      "targeted": false
    },
    {
      "action_name": "filesystem.RETURN_LIST",
      "summary": "The response envelope containing a directory listing (as paths), delivered to the original requester.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "listing": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/FileEntry"
            }
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "correlationId": {
            "type": [
              "string",
              "null"
            ],
            "description": "Correlation ID passed through from the original LIST request."
          }
        },
        "required": [
          "listing"
        ]
      }
    },
    {
      "action_name": "filesystem.RETURN_READ",
      "summary": "The response envelope containing the content of a file, delivered to the original requester.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "content": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "path"
        ]
      }
    },
    {
      "action_name": "filesystem.RETURN_FILES_CONTENT",
      "summary": "The response envelope containing the content of multiple files. Paths MUST be relative to the root of the read operation.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": [
              "string",
              "null"
            ]
          },
          "contents": {
            "type": "object",
            "description": "A map of relative file paths to their string content.",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": [
          "contents"
        ]
      }
    },
    {
      "action_name": "filesystem.ACTION_RESULT",
      "summary": "Broadcast notification published after a command-dispatchable domain action completes. Carries a lightweight, privacy-safe summary — never raw data or sandbox-internal paths. CommandBot matches via correlationId to post feedback to the originating session. Other observers (logging plugins, usage monitors) may also subscribe.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": ["string", "null"],
            "description": "From the domain action's payload. Null if not command-originated."
          },
          "requestAction": {
            "type": "string",
            "description": "The domain action name that produced this result, e.g. 'filesystem.SYSTEM_READ'."
          },
          "success": {
            "type": "boolean"
          },
          "summary": {
            "type": ["string", "null"],
            "description": "Human-readable, privacy-safe description of what happened. No sandbox paths."
          },
          "error": {
            "type": ["string", "null"],
            "description": "Human-readable error message. Present when success is false."
          }
        },
        "required": ["requestAction", "success"]
      }
    }
  ],
  "definitions": {
    "FileEntry": {
      "type": "object",
      "description": "Represents a file or directory. The 'path' property MUST be a path relative to the originator's sandbox.",
      "properties": {
        "path": {
          "type": "string"
        },
        "isDirectory": {
          "type": "boolean"
        },
        "lastModified": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Last modified time in epoch milliseconds. Null if unavailable."
        }
      }
    }
  }
}