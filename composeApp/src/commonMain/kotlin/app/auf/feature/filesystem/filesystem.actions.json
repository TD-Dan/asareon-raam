{
  "feature_name": "filesystem",
  "summary": "Acts as the sole, transactional, and secure gateway to the file system.",
  "listensFor": [
    {
      "action_name": "filesystem.NAVIGATE",
      "summary": "Requests to change the currently viewed directory path.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.SELECT_DIRECTORY_UI",
      "summary": "Triggers the native OS file chooser to select a directory.",
      "payload_schema": null
    },
    {
      "action_name": "filesystem.LOAD_CHILDREN",
      "summary": "[INTERNAL] Triggers a side-effect to load a directory's children from disk.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.SYSTEM_LIST",
      "summary": "[PRIVATE-CHANNEL] Requests a listing of files in the originator's private sandbox. Request is delivered via private channel with 'filesystem.response.list' as type",
      "payload_schema": null
    },
    {
      "action_name": "filesystem.SYSTEM_READ",
      "summary": "[INTERNAL-SANDBOXED] Requests to read a file from the originator's private sandbox.",
      "payload_schema": {
        "type": "object",
        "properties": { "subpath": { "type": "string" } },
        "required": ["subpath"]
      }
    },
    {
      "action_name": "filesystem.SYSTEM_WRITE",
      "summary": "[INTERNAL-SANDBOXED] Requests to write a file to the originator's private sandbox.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "subpath": { "type": "string" },
          "content": { "type": "string" },
          "encrypt": {
            "type": "boolean",
            "description": "If true, the content will be encrypted at rest. Defaults to false.",
            "default": false
          }
        },
        "required": ["subpath", "content"]
      }
    },
    {
      "action_name": "filesystem.SYSTEM_DELETE",
      "summary": "[INTERNAL-SANDBOXED] Requests to delete a file from the originator's private sandbox.",
      "payload_schema": {
        "type": "object",
        "properties": { "subpath": { "type": "string" } },
        "required": ["subpath"]
      }
    },
    {
      "action_name": "filesystem.SYSTEM_DELETE_DIRECTORY",
      "summary": "[INTERNAL-SANDBOXED] Requests to recursively delete a directory from the originator's private sandbox.",
      "payload_schema": {
        "type": "object",
        "properties": { "subpath": { "type": "string" } },
        "required": ["subpath"]
      }
    },
    {
      "action_name": "filesystem.OPEN_SYSTEM_FOLDER",
      "summary": "[INTERNAL-SANDBOXED] Requests to open the originator's private sandbox in the OS file explorer.",
      "payload_schema": null
    },
    {
      "action_name": "filesystem.OPEN_APP_SUBFOLDER",
      "summary": "[INTERNAL] Requests to open a well-known subfolder within the app's secure data zone (e.g., 'logs').",
      "payload_schema": {
        "type": "object",
        "properties": { "folder": { "type": "string" } },
        "required": ["folder"]
      }
    },
    {
      "action_name": "filesystem.EXPAND_ALL",
      "summary": "Recursively expands a directory in the tree view to a safe depth.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.COLLAPSE_ALL",
      "summary": "Recursively collapses a directory and all its children in the tree view.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.ADD_WHITELIST_PATH",
      "summary": "Adds a new directory path to the security whitelist.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.REMOVE_WHITELIST_PATH",
      "summary": "Removes a directory path from the security whitelist.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.ADD_FAVORITE_PATH",
      "summary": "Adds a new directory path to the user's favorites.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.REMOVE_FAVORITE_PATH",
      "summary": "Removes a directory path from the user's favorites.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.TOGGLE_ITEM_EXPANDED",
      "summary": "Toggles the expanded/collapsed state of a directory in the tree view.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.TOGGLE_ITEM_SELECTED",
      "summary": "Toggles the selected/deselected state of a file or directory.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "recursive": { "type": "boolean", "default": false }
        },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.COPY_SELECTION_TO_CLIPBOARD",
      "summary": "Initiates the process of reading selected files and copying their formatted content to the clipboard.",
      "payload_schema": null
    },
    {
      "action_name": "filesystem.STAGE_CREATE",
      "summary": "Stages a new 'Create' operation in the transaction buffer.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "content": { "type": "string" }
        },
        "required": ["path", "content"]
      }
    },
    {
      "action_name": "filesystem.STAGE_UPDATE",
      "summary": "Stages a new 'Update' operation in the transaction buffer.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "newContent": { "type": "string" }
        },
        "required": ["path", "newContent"]
      }
    },
    {
      "action_name": "filesystem.STAGE_DELETE",
      "summary": "Stages a new 'Delete' operation in the transaction buffer.",
      "payload_schema": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "action_name": "filesystem.COMMIT",
      "summary": "Executes all staged operations within the security sandbox.",
      "payload_schema": null
    },
    {
      "action_name": "filesystem.DISCARD",
      "summary": "Clears all staged operations without executing them.",
      "payload_schema": null
    }
  ],
  "publishes": [
    {
      "action_name": "filesystem.publish.NAVIGATION_UPDATED",
      "summary": "Broadcasts that the directory listing has been successfully updated.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "listing": {
            "type": "array",
            "items": { "$ref": "#/definitions/FileEntry" }
          }
        }
      }
    },
    {
      "action_name": "filesystem.publish.NAVIGATION_FAILED",
      "summary": "Broadcasts that a navigation attempt failed.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    {
      "action_name": "filesystem.internal.DIRECTORY_LOADED",
      "summary": "[INTERNAL] Dispatched after a directory's children have been loaded from disk.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "parentPath": { "type": "string" },
          "children": {
            "type": "array",
            "items": { "$ref": "#/definitions/FileEntry" }
          }
        },
        "required": ["parentPath", "children"]
      }
    }
  ],
  "private_envelopes": [
    {
      "type_name": "filesystem.response.LIST",
      "summary": "The response envelope containing a directory listing, delivered to the original requester.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "listing": {
            "type": "array",
            "items": { "$ref": "#/definitions/FileEntry" }
          },
          "subpath": { "type": ["string", "null"] }
        },
        "required": ["listing"]
      }
    },
    {
      "type_name": "filesystem.response.READ",
      "summary": "The response envelope containing the content of a file, delivered to the original requester.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "subpath": { "type": "string" },
          "content": { "type": ["string", "null"] }
        },
        "required": ["subpath"]
      }
    }
  ],
  "definitions": {
    "FileEntry": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "isDirectory": { "type": "boolean" }
      }
    }
  }
}