{
  "feature_name": "knowledgegraph",
  "summary": "The master source of truth for loading, managing, and visualizing a single, hierarchical Holon Knowledge Graph (HKG) tree.",
  "listensFor": [
    {
      "action_name": "knowledgegraph.SELECT_PERSONA",
      "summary": "Sets the active AI Persona, which acts as the root of the HKG to be loaded and displayed.",
      "payload_schema": { "type": "object", "properties": { "personaId": { "type": ["string", "null"] } } }
    },
    {
      "action_name": "knowledgegraph.SELECT_HOLON",
      "summary": "Selects a specific holon for detailed viewing in the UI.",
      "payload_schema": { "type": "object", "properties": { "holonId": { "type": ["string", "null"] } } }
    },
    {
      "action_name": "knowledgegraph.CREATE_PERSONA",
      "summary": "Creates a new, empty AI Persona Root holon, establishing a new HKG.",
      "payload_schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] }
    },
    {
      "action_name": "knowledgegraph.DELETE_PERSONA",
      "summary": "Deletes an entire HKG by deleting its root persona directory.",
      "payload_schema": { "type": "object", "properties": { "personaId": { "type": "string" } }, "required": ["personaId"] }
    },
    {
      "action_name": "knowledgegraph.UPDATE_HOLON",
      "summary": "Creates or updates a holon file within the active HKG.",
      "payload_schema": { "type": "object", "properties": { "holonId": { "type": "string" }, "content": { "type": "string" } }, "required": ["holonId", "content"] }
    },
    {
      "action_name": "knowledgegraph.DELETE_HOLON",
      "summary": "Deletes a holon file from the active HKG.",
      "payload_schema": { "type": "object", "properties": { "holonId": { "type": "string" } }, "required": ["holonId"] }
    }
  ],
  "publishes": [
    {
      "action_name": "knowledgegraph.publish.AVAILABLE_PERSONAS_UPDATED",
      "summary": "Broadcasts the list of all discovered, valid AI_Persona_Root holon headers.",
      "payload_schema": { "type": "object", "properties": { "personas": { "type": "array" } }, "required": ["personas"] }
    },
    {
      "action_name": "knowledgegraph.internal.PERSONA_DISCOVERED",
      "summary": "[INTERNAL] Dispatched when a valid AI_Persona_Root is found and parsed.",
      "payload_schema": { "type": "object" }
    },
    {
      "action_name": "knowledgegraph.internal.HOLON_LOADED",
      "summary": "[INTERNAL] Dispatched when a single holon's content is parsed and added to the graph.",
      "payload_schema": { "type": "object" }
    },
    {
      "action_name": "knowledgegraph.internal.LOAD_FAILED",
      "summary": "[INTERNAL] Dispatched when loading or parsing fails fatally.",
      "payload_schema": { "type": "object", "properties": { "error": { "type": "string" } } }
    }
  ],
  "private_envelopes": [
    {
      "type_name": "knowledgegraph.response.context",
      "summary": "The response envelope containing the compiled HKG context for an agent's turn.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": { "type": "string" },
          "context": { "type": "object" }
        },
        "required": ["correlationId", "context"]
      }
    }
  ]
}