{
  "feature_name": "core",
  "summary": "Handles core, application-level state and UI logic like navigation, toasts, user identity management, and the universal identity registry.",
  "permissions": [
    { "key": "core:read", "description": "Read core state and identity information", "dangerLevel": "LOW" },
    { "key": "core:identity", "description": "Modify identity records", "dangerLevel": "CAUTION" },
    { "key": "core:admin", "description": "Full administrative access to core operations", "dangerLevel": "DANGER" }
  ],
  "actions": [
    {
      "action_name": "core.SET_ACTIVE_VIEW",
      "summary": "Changes the main view displayed in the UI.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "hidden": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          }
        },
        "required": [
          "key"
        ]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.SHOW_DEFAULT_VIEW",
      "summary": "Changes the main view to whatever is configured as the default view.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "hidden": true,
      "required_permissions": []
    },
    {
      "action_name": "core.UPDATE_WINDOW_SIZE",
      "summary": "Updates the application state with the new window dimensions, typically after a user resize.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "hidden": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          }
        },
        "required": [
          "width",
          "height"
        ]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.SHOW_TOAST",
      "summary": "Displays a short-lived message at the bottom of the screen.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.CLEAR_TOAST",
      "summary": "Immediately hides the currently displayed toast message.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "hidden": true,
      "required_permissions": []
    },
    {
      "action_name": "core.OPEN_LOGS_FOLDER",
      "summary": "Requests that the application's logs folder be opened in the native file explorer.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "required_permissions": []
    },
    {
      "action_name": "core.COPY_TO_CLIPBOARD",
      "summary": "Copies the provided text to the system clipboard.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.ADD_USER_IDENTITY",
      "summary": "Adds a new user identity to the application.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "required_permissions": ["core:identity"]
    },
    {
      "action_name": "core.REMOVE_USER_IDENTITY",
      "summary": "Removes an existing user identity.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      },
      "required_permissions": ["core:identity"]
    },
    {
      "action_name": "core.SET_ACTIVE_USER_IDENTITY",
      "summary": "Sets the specified user identity as the active one for the application.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      },
      "required_permissions": ["core:admin"]
    },
    {
      "action_name": "core.SHOW_CONFIRMATION_DIALOG",
      "summary": "Requests the Core feature to display a generic, modal confirmation dialog.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "hidden": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "confirmButtonText": {
            "type": "string"
          },
          "requestId": {
            "type": "string",
            "description": "A unique ID for the requesting feature to track the response."
          },
          "cancelButtonText": {
            "type": [
              "string",
              "null"
            ]
          },
          "isDestructive": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "title",
          "text",
          "confirmButtonText",
          "requestId"
        ]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.DISMISS_CONFIRMATION_DIALOG",
      "summary": "Clears any active confirmation dialog from the UI. Dispatches a private response if it was a confirmation.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "hidden": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "confirmed": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "confirmed"
        ]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.IDENTITIES_UPDATED",
      "summary": "Broadcasts the complete state of user identities after any change.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "identities": {
            "type": "array",
            "description": "The full list of Identity objects.",
            "items": {
              "type": "object"
            }
          },
          "activeId": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "identities"
        ]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.IDENTITIES_LOADED",
      "summary": "[INTERNAL] Dispatched after user identities have been loaded from disk.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "identities": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "activeId": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "identities"
        ]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.RETURN_CONFIRMATION",
      "summary": "The private response envelope sent to the original feature that requested a confirmation dialog.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string"
          },
          "confirmed": {
            "type": "boolean"
          }
        },
        "required": [
          "requestId",
          "confirmed"
        ]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.REGISTER_IDENTITY",
      "summary": "Register a new identity in the universal registry. If localHandle is omitted, CoreFeature generates one from the name via slugification. If a UUID is provided and valid, it is used instead of auto-generating one (useful for correlation). The originator automatically becomes the parent. CoreFeature validates localHandle format if provided, deduplicates among siblings, and returns the approved identity via a targeted RETURN_REGISTER_IDENTITY.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "localHandle": {
            "type": ["string", "null"],
            "description": "Optional leaf-level handle. If provided, must match [a-z][a-z0-9-]*. If omitted, generated from name."
          },
          "name": {
            "type": "string",
            "description": "Human-readable display name (full Unicode allowed). Required."
          },
          "uuid": {
            "type": ["string", "null"],
            "description": "Optional caller-provided UUID. Must be valid UUID format (8-4-4-4-12 hex). If omitted, auto-generated."
          },
          "displayColor": {
            "type": ["string", "null"],
            "description": "Optional display color as '#RRGGBB' hex. Used for accent borders and name coloring in session cards."
          },
          "displayIcon": {
            "type": ["string", "null"],
            "description": "Optional Material icon key (e.g., 'bolt', 'pets', 'science'). Tinted with displayColor when rendered."
          },
          "displayEmoji": {
            "type": ["string", "null"],
            "description": "Optional emoji override (e.g., '🦊'). Takes precedence over displayIcon, renders full-color."
          }
        },
        "required": ["name"]
      },
      "required_permissions": ["core:identity"]
    },
    {
      "action_name": "core.RETURN_REGISTER_IDENTITY",
      "summary": "Targeted response to a core.REGISTER_IDENTITY request. Contains the approved identity on success, or an error on failure.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "requestedLocalHandle": { "type": "string" },
          "approvedLocalHandle": { "type": "string" },
          "handle": { "type": "string" },
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "parentHandle": { "type": "string" },
          "error": { "type": "string" }
        },
        "required": ["success"]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.UNREGISTER_IDENTITY",
      "summary": "Remove an identity from the registry. Cascades: all descendants are also removed. Namespace enforcement: the originator can only unregister identities within its own namespace.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "handle": {
            "type": "string",
            "description": "Full handle of the identity to remove."
          }
        },
        "required": ["handle"]
      },
      "required_permissions": ["core:admin"]
    },
    {
      "action_name": "core.IDENTITY_REGISTRY_UPDATED",
      "summary": "Broadcast after any change to the identity registry.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "required_permissions": []
    },
    {
      "action_name": "core.UPDATE_IDENTITY",
      "summary": "Update the name (and consequently the handle/slug) of an existing identity.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "handle": { "type": "string" },
          "newName": { "type": "string" },
          "displayColor": {
            "type": ["string", "null"],
            "description": "Optional display color as '#RRGGBB' hex. If key is present, updates the color (null clears it). If key is absent, existing color is preserved."
          },
          "displayIcon": {
            "type": ["string", "null"],
            "description": "Optional Material icon key. Same presence semantics as displayColor."
          },
          "displayEmoji": {
            "type": ["string", "null"],
            "description": "Optional emoji override. Same presence semantics as displayColor."
          }
        },
        "required": ["handle", "newName"]
      },
      "required_permissions": ["core:admin"]
    },
    {
      "action_name": "core.RETURN_UPDATE_IDENTITY",
      "summary": "Targeted response to a core.UPDATE_IDENTITY request.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "oldHandle": { "type": "string" },
          "newHandle": { "type": "string" },
          "oldLocalHandle": { "type": "string" },
          "newLocalHandle": { "type": "string" },
          "name": { "type": "string" },
          "uuid": { "type": "string" },
          "error": { "type": "string" }
        },
        "required": ["success", "oldHandle"]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.REGISTER_PENDING_COMMAND",
      "summary": "[INTERNAL] Records a correlationId → session mapping when CoreFeature dispatches a domain action on behalf of a user command.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": { "type": "string" },
          "sessionId": { "type": "string" },
          "actionName": { "type": "string" },
          "originatorId": { "type": "string" }
        },
        "required": ["correlationId", "sessionId", "actionName", "originatorId"]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.CLEAR_PENDING_COMMAND",
      "summary": "[INTERNAL] Removes a pending command entry after the result has been forwarded to the session, or on TTL expiry.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": { "type": "string" }
        },
        "required": ["correlationId"]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.SET_PERMISSION",
      "summary": "Sets a single permission grant on an identity. Only dispatchable by CoreFeature (non-public). The Permission Manager UI operates through Core's trusted handle.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "identityHandle": { "type": "string", "description": "The handle of the identity to modify." },
          "permissionKey": { "type": "string", "description": "The permission key (e.g., 'filesystem:workspace')." },
          "level": { "type": "string", "description": "The permission level. ASK and APP_LIFETIME are reserved for the ASK system." }
        },
        "required": ["identityHandle", "permissionKey", "level"]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.SET_PERMISSIONS_BATCH",
      "summary": "Bulk-sets multiple permission grants. Used by the matrix UI and initial config loading. Non-public — only dispatchable by CoreFeature.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "grants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "identityHandle": { "type": "string" },
                "permissionKey": { "type": "string" },
                "level": { "type": "string" }
              },
              "required": ["identityHandle", "permissionKey", "level"]
            }
          }
        },
        "required": ["grants"]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.PERMISSIONS_UPDATED",
      "summary": "Broadcast after any permission change. Features that cache permission state should refresh.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "required_permissions": []
    },
    {
      "action_name": "core.PERMISSION_DENIED",
      "summary": "Broadcast notification sent when an action is blocked by the permission guard. Allows observing features (e.g., CommandBot) to provide user-facing feedback.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "blockedAction": { "type": "string" },
          "originatorHandle": { "type": "string" },
          "missingPermissions": { "type": "array", "items": { "type": "string" } },
          "sessionId": { "type": ["string", "null"], "description": "Session context for feedback, if available." }
        },
        "required": ["blockedAction", "originatorHandle", "missingPermissions"]
      },
      "required_permissions": []
    },
    {
      "action_name": "core.REQUEST_PERMISSION_ESCALATION",
      "summary": "Paved action name for future runtime permission escalation requests. Analogous to Android's runtime permission request flow. NOT YET IMPLEMENTED — dispatching this action is a no-op until a use case emerges.",
      "public": true,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "requestingHandle": { "type": "string", "description": "Identity handle requesting elevated permissions." },
          "requestedPermissions": { "type": "array", "items": { "type": "string" }, "description": "Permission keys being requested." },
          "reason": { "type": "string", "description": "Human-readable justification for the escalation." }
        },
        "required": ["requestingHandle", "requestedPermissions"]
      },
      "required_permissions": ["core:admin"]
    }
  ]
}