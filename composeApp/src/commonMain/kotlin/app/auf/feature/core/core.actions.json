{
  "feature_name": "core",
  "summary": "Handles core, application-level state and UI logic like navigation, toasts, and user identity management.",
  "listensFor": [
    {
      "action_name": "core.SET_ACTIVE_VIEW",
      "summary": "Changes the main view displayed in the UI.",
      "payload_schema": {
        "type": "object",
        "properties": { "key": { "type": "string" } },
        "required": ["key"]
      }
    },
    {
      "action_name": "core.SHOW_DEFAULT_VIEW",
      "summary": "Changes the main view to whatever is configured as the default view.",
      "payload_schema": null
    },
    {
      "action_name": "core.UPDATE_WINDOW_SIZE",
      "summary": "Updates the application state with the new window dimensions, typically after a user resize.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "width": { "type": "integer" },
          "height": { "type": "integer" }
        },
        "required": ["width", "height"]
      }
    },
    {
      "action_name": "core.SHOW_TOAST",
      "summary": "Displays a short-lived message at the bottom of the screen.",
      "payload_schema": {
        "type": "object",
        "properties": { "message": { "type": "string" } },
        "required": ["message"]
      }
    },
    {
      "action_name": "core.CLEAR_TOAST",
      "summary": "Immediately hides the currently displayed toast message.",
      "payload_schema": null
    },
    {
      "action_name": "core.OPEN_LOGS_FOLDER",
      "summary": "Requests that the application's logs folder be opened in the native file explorer.",
      "payload_schema": null
    },
    {
      "action_name": "core.COPY_TO_CLIPBOARD",
      "summary": "Copies the provided text to the system clipboard.",
      "payload_schema": {
        "type": "object",
        "properties": { "text": { "type": "string" } },
        "required": ["text"]
      }
    },
    {
      "action_name": "core.ADD_USER_IDENTITY",
      "summary": "Adds a new user identity to the application.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    {
      "action_name": "core.REMOVE_USER_IDENTITY",
      "summary": "Removes an existing user identity.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" }
        },
        "required": ["id"]
      }
    },
    {
      "action_name": "core.SET_ACTIVE_USER_IDENTITY",
      "summary": "Sets the specified user identity as the active one for the application.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" }
        },
        "required": ["id"]
      }
    },
    {
      "action_name": "core.SHOW_CONFIRMATION_DIALOG",
      "summary": "Requests the Core feature to display a generic, modal confirmation dialog.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "text": { "type": "string" },
          "confirmButtonText": { "type": "string" },
          "onConfirmAction": { "type": "object", "description": "A complete, serialized Action object to be dispatched upon confirmation." }
        },
        "required": ["title", "text", "confirmButtonText", "onConfirmAction"]
      }
    },
    {
      "action_name": "core.DISMISS_CONFIRMATION_DIALOG",
      "summary": "Clears any active confirmation dialog from the UI.",
      "payload_schema": null
    }
  ],
  "publishes": [
    {
      "action_name": "core.publish.IDENTITIES_UPDATED",
      "summary": "Broadcasts the complete state of user identities after any change.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "identities": {
            "type": "array",
            "description": "The full list of Identity objects.",
            "items": {
              "type": "object"
            }
          },
          "activeId": {
            "type": ["string", "null"]
          }
        },
        "required": ["identities"]
      }
    },
    {
      "action_name": "core.internal.IDENTITIES_LOADED",
      "summary": "[INTERNAL] Dispatched after user identities have been loaded from disk.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "identities": {
            "type": "array",
            "items": { "type": "object" }
          },
          "activeId": { "type": ["string", "null"] }
        },
        "required": ["identities"]
      }
    }
  ]
}