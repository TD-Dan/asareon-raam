{
  "feature_name": "agent",
  "summary": "Hosts and manages the lifecycle of autonomous, HKG-driven AI agents.",
  "actions": [
    {
      "action_name": "agent.CREATE",
      "summary": "Creates a new agent instance with the specified configuration.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "knowledgeGraphId": {
            "type": [
              "string",
              "null"
            ]
          },
          "modelProvider": {
            "type": "string"
          },
          "modelName": {
            "type": "string"
          },
          "cognitiveStrategyId": {
            "type": "string"
          },
          "subscribedSessionIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "automaticMode": {
            "type": "boolean",
            "default": false
          },
          "autoWaitTimeSeconds": {
            "type": "integer"
          },
          "autoMaxWaitTimeSeconds": {
            "type": "integer"
          },
          "correlationId": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional correlation ID for command-dispatch feedback via agent.ACTION_RESULT.",
            "default": null
          }
        },
        "required": [
          "name"
        ]
      }
    },
    {
      "action_name": "agent.CLONE",
