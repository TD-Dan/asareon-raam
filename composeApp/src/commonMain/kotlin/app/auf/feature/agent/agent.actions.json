{
  "feature_name":"agent",
  "summary":"Hosts and manages the lifecycle of autonomous, HKG-driven AI agents.",
  "listensFor":[
    {
      "action_name":"agent.CREATE",
      "summary":"Creates a new agent instance with the specified configuration.",
      "payload_schema":{
        "type":"object",
        "properties":{
          "name":{ "type":"string" },
          "knowledgeGraphId":{ "type":[ "string", "null" ] },
          "modelProvider":{ "type":"string" },
          "modelName":{ "type":"string" },
          "subscribedSessionIds":{ "type": "array", "items": { "type": "string" }, "description":"The sessions this agent will post its responses to." },
          "automaticMode":{ "type":"boolean", "default":false },
          "autoWaitTimeSeconds": { "type": "integer" },
          "autoMaxWaitTimeSeconds": { "type": "integer" }
        },
        "required":[ "name" ]
      }
    },
    {
      "action_name": "agent.CLONE",
      "summary": "Creates a new agent instance by cloning an existing one.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name":"agent.UPDATE_CONFIG",
      "summary":"Updates the configuration of an existing agent instance. All payload properties are optional.",
      "payload_schema":{
        "type":"object",
        "properties":{
          "agentId":{ "type":"string" },
          "name":{ "type":"string" },
          "knowledgeGraphId":{ "type":[ "string", "null" ] },
          "privateSessionId": { "type": [ "string", "null" ] },
          "modelProvider":{ "type":"string" },
          "modelName":{ "type":"string" },
          "subscribedSessionIds":{ "type": "array", "items": { "type": "string" } },
          "automaticMode":{ "type":"boolean" },
          "autoWaitTimeSeconds": { "type": "integer" },
          "autoMaxWaitTimeSeconds": { "type": "integer" }
        },
        "required":[ "agentId" ]
      }
    },
    {
      "action_name":"agent.DELETE",
      "summary":"Deletes an agent instance.",
      "payload_schema":{
        "type":"object",
        "properties":{ "agentId":{ "type":"string" } },
        "required":[ "agentId" ]
      }
    },
    {
      "action_name":"agent.TOGGLE_AUTOMATIC_MODE",
      "summary":"Toggles the automatic processing mode for a specific agent.",
      "payload_schema":{
        "type":"object",
        "properties":{ "agentId":{ "type":"string" } },
        "required":[ "agentId" ]
      }
    },
    {
      "action_name": "agent.TOGGLE_ACTIVE",
      "summary": "Toggles the master active/paused state for a specific agent.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.INITIATE_TURN",
      "summary": "A unified action to start an agent's turn, either directly or by first entering a preview mode.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": { "type": "string" },
          "preview": {
            "type": "boolean",
            "default": false,
            "description": "If true, the turn context will be staged for user review before execution."
          }
        },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.EXECUTE_PREVIEWED_TURN",
      "summary": "Executes the turn that was previously staged for preview.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.DISCARD_PREVIEW",
      "summary": "Discards a turn that was staged for preview and navigates back.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name":"agent.CANCEL_TURN",
      "summary":"Cancels an agent's currently in-flight, processing turn.",
      "payload_schema":{
        "type":"object",
        "properties":{ "agentId":{ "type":"string" } },
        "required":[ "agentId" ]
      }
    },
    {
      "action_name":"agent.SET_EDITING",
      "summary":"Sets which agent is currently being edited in the UI.",
      "payload_schema":{
        "type":"object",
        "properties":{ "agentId":{ "type":[ "string", "null" ] } }
      }
    },
    {
      "action_name": "knowledgegraph.publish.RESERVATIONS_UPDATED",
      "summary": "Listens for updates to the set of reserved HKGs to prevent UI conflicts.",
      "payload_schema": {
        "type": "object",
        "properties": { "reservedIds": { "type": "array", "items": { "type": "string" } } },
        "required": ["reservedIds"]
      }
    }
  ],
  "publishes":[
    {
      "action_name":"agent.publish.AGENT_NAMES_UPDATED",
      "summary":"Broadcasts the verified map of agent IDs to their names.",
      "payload_schema":{ "type":"object", "properties":{ "names":{ "type":"object", "description":"A map where the key is the agent ID and the value is the agent's name." } }, "required":[ "names" ] }
    },
    {
      "action_name":"agent.publish.AGENT_DELETED",
      "summary":"Broadcasts that an agent has been deleted, so other features can clean up their state.",
      "payload_schema":{ "type":"object", "properties":{ "agentId":{ "type":"string" } }, "required":[ "agentId" ] }
    },
    {
      "action_name":"agent.internal.AGENT_LOADED",
      "summary":"[INTERNAL] Dispatched after an agent's configuration has been read from its sandbox. Used to populate the feature's state.",
      "payload_schema":{ "type":"object", "description":"A single AgentInstance object." }
    },
    {
      "action_name":"agent.internal.AGENTS_LOADED",
      "summary":"[INTERNAL] Dispatched after all agent configurations have been read from disk. Triggers post-load validation.",
      "payload_schema":null
    },
    {
      "action_name":"agent.internal.VALIDATE_SOVEREIGN_STATE",
      "summary":"[INTERNAL] Triggers the validation of sovereign agent requirements (reservations, private sessions) on startup.",
      "payload_schema":null
    },
    {
      "action_name": "agent.internal.CHECK_AUTOMATIC_TRIGGERS",
      "summary": "[INTERNAL] Dispatched by a timer to check if any automatic agents should start their cognitive cycle.",
      "payload_schema": null
    },
    {
      "action_name": "agent.internal.UPDATE_AUTO_TRIGGER_INDEX",
      "summary": "[INTERNAL] Updates the index for the round-robin automatic trigger.",
      "payload_schema": {
        "type": "object", "properties": { "index": { "type": "integer" } }, "required": ["index"]
      }
    },
    {
      "action_name": "agent.internal.STAGE_TURN_CONTEXT",
      "summary": "[INTERNAL] Caches the ledger messages while the HKG context is being fetched.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": { "type": "string" },
          "messages": { "type": "array", "items": { "type": "object" } }
        },
        "required": ["agentId", "messages"]
      }
    },
    {
      "action_name": "agent.internal.SET_PREVIEW_DATA",
      "summary": "[INTERNAL] Saves the complete preview data (agnostic and raw) received from the Gateway.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": { "type": "string" },
          "agnosticRequest": { "type": "object" },
          "rawRequestJson": { "type": "string" }
        },
        "required": [ "agentId", "agnosticRequest", "rawRequestJson" ]
      }
    },
    {
      "action_name":"agent.internal.CONFIRM_DELETE",
      "summary":"[INTERNAL] Dispatched after cleanup side effects are complete to commit the deletion to the state.",
      "payload_schema":{ "type":"object", "properties":{ "agentId":{ "type":"string" } }, "required":[ "agentId" ] }
    },
    {
      "action_name":"agent.internal.SET_STATUS",
      "summary":"[INTERNAL] Updates the transient status and optional error message for an agent.",
      "payload_schema":{
        "type":"object",
        "properties":{
          "agentId":{ "type":"string" },
          "status":{ "type":"string", "enum":[ "IDLE", "WAITING", "PROCESSING", "ERROR" ] },
          "error":{ "type":[ "string", "null" ] }
        },
        "required":[ "agentId", "status" ]
      }
    },
    {
      "action_name": "agent.internal.SET_PROCESSING_STEP",
      "summary": "[INTERNAL] Updates the human-readable description of the agent's current processing activity.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": { "type": "string" },
          "step": { "type": [ "string", "null" ] }
        },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.internal.SET_HKG_CONTEXT",
      "summary": "[INTERNAL] Caches the fetched HKG context for the duration of a single cognitive turn.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": { "type": "string" },
          "context": { "type": "object" }
        },
        "required": ["agentId", "context"]
      }
    }
  ],
  "private_envelopes": [
    {
      "type_name": "agent.request.context",
      "summary": "A request envelope sent to the KnowledgeGraphFeature to ask for the context of a specific HKG.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": { "type": "string" },
          "knowledgeGraphId": { "type": "string" }
        },
        "required": ["correlationId", "knowledgeGraphId"]
      }
    }
  ]
}