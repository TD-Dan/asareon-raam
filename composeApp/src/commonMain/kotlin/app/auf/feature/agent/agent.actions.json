{
  "feature_name": "agent",
  "summary": "Hosts and manages the lifecycle of autonomous, HKG-driven AI agents.",
  "listensFor": [
    {
      "action_name": "agent.CREATE",
      "summary": "Creates a new agent instance with the specified configuration.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "knowledgeGraphId": { "type": [ "string", "null" ] },
          "modelProvider": { "type": "string" },
          "modelName": { "type": "string" },
          "cognitiveStrategyId": { "type": "string" },
          "subscribedSessionIds": { "type": "array", "items": { "type": "string" } },
          "automaticMode": { "type": "boolean", "default": false },
          "autoWaitTimeSeconds": { "type": "integer" },
          "autoMaxWaitTimeSeconds": { "type": "integer" }
        },
        "required": [ "name" ]
      }
    },
    {
      "action_name": "agent.CLONE",
      "summary": "Creates a new agent instance by cloning an existing one.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.UPDATE_CONFIG",
      "summary": "Updates the configuration of an existing agent instance. All payload properties are optional.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": { "type": "string" },
          "name": { "type": "string" },
          "knowledgeGraphId": { "type": [ "string", "null" ] },
          "privateSessionId": { "type": [ "string", "null" ] },
          "modelProvider": { "type": "string" },
          "modelName": { "type": "string" },
          "cognitiveStrategyId": { "type": "string" },
          "subscribedSessionIds": { "type": "array", "items": { "type": "string" } },
          "automaticMode": { "type": "boolean" },
          "autoWaitTimeSeconds": { "type": "integer" },
          "autoMaxWaitTimeSeconds": { "type": "integer" }
        },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.DELETE",
      "summary": "Deletes an agent instance.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.TOGGLE_AUTOMATIC_MODE",
      "summary": "Toggles the automatic processing mode for a specific agent.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.TOGGLE_ACTIVE",
      "summary": "Toggles the master active/paused state for a specific agent.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.INITIATE_TURN",
      "summary": "A unified action to start an agent's turn, either directly or by first entering a preview mode.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": { "type": "string" },
          "preview": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.EXECUTE_PREVIEWED_TURN",
      "summary": "Executes the turn that was previously staged for preview.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.DISCARD_PREVIEW",
      "summary": "Discards a turn that was staged for preview and navigates back.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.CANCEL_TURN",
      "summary": "Cancels an agent's currently in-flight, processing turn.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": "string" } },
        "required": [ "agentId" ]
      }
    },
    {
      "action_name": "agent.SET_EDITING",
      "summary": "Sets which agent is currently being edited in the UI.",
      "payload_schema": {
        "type": "object",
        "properties": { "agentId": { "type": [ "string", "null" ] } }
      }
    },
    {
      "action_name": "knowledgegraph.publish.RESERVATIONS_UPDATED",
      "summary": "Listens for updates to the set of reserved HKGs to prevent UI conflicts.",
      "payload_schema": {
        "type": "object",
        "properties": { "reservedIds": { "type": "array", "items": { "type": "string" } } },
        "required": ["reservedIds"]
      }
    },
    {
      "action_name": "agent.SET_MANAGER_TAB",
      "summary": "Switches the active tab in the Agent Manager View.",
      "payload_schema": {
        "type": "object",
        "properties": { "tabIndex": { "type": "integer" } },
        "required": ["tabIndex"]
      }
    },
    {
      "action_name": "agent.SELECT_RESOURCE",
      "summary": "Selects a system resource for viewing/editing.",
      "payload_schema": {
        "type": "object",
        "properties": { "resourceId": { "type": [ "string", "null" ] } }
      }
    },
    {
      "action_name": "agent.SAVE_RESOURCE",
      "summary": "Saves changes to a system resource.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "resourceId": { "type": "string" },
          "content": { "type": "string" }
        },
        "required": ["resourceId", "content"]
      }
    },
    {
      "action_name": "agent.CREATE_RESOURCE",
      "summary": "Creates a new user-defined system resource.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" }
        },
        "required": ["name", "type"]
      }
    },
    {
      "action_name": "agent.DELETE_RESOURCE",
      "summary": "Deletes a user-defined system resource.",
      "payload_schema": {
        "type": "object",
        "properties": { "resourceId": { "type": "string" } },
        "required": ["resourceId"]
      }
    }
  ],
  "publishes": [
    {
      "action_name": "agent.publish.AGENT_NAMES_UPDATED",
      "summary": "Broadcasts the verified map of agent IDs to their names.",
      "payload_schema": { "type": "object", "properties": { "names": { "type": "object" } }, "required": [ "names" ] }
    },
    {
      "action_name": "agent.publish.AGENT_DELETED",
      "summary": "Broadcasts that an agent has been deleted, so other features can clean up their state.",
      "payload_schema": { "type": "object", "properties": { "agentId": { "type": "string" } }, "required": [ "agentId" ] }
    },
    {
      "action_name": "agent.internal.AGENT_LOADED",
      "summary": "[INTERNAL] Dispatched after an agent's configuration has been read from its sandbox.",
      "payload_schema": { "type": "object" }
    },
    {
      "action_name": "agent.internal.AGENTS_LOADED",
      "summary": "[INTERNAL] Dispatched after all agent configurations have been read from disk.",
      "payload_schema": null
    },
    {
      "action_name": "agent.internal.VALIDATE_SOVEREIGN_STATE",
      "summary": "[INTERNAL] Triggers the validation of sovereign agent requirements on startup.",
      "payload_schema": null
    },
    {
      "action_name": "agent.internal.CHECK_AUTOMATIC_TRIGGERS",
      "summary": "[INTERNAL] Dispatched by a timer to check if any automatic agents should start their cognitive cycle.",
      "payload_schema": null
    },
    {
      "action_name": "agent.internal.UPDATE_AUTO_TRIGGER_INDEX",
      "summary": "[INTERNAL] Updates the index for the round-robin automatic trigger.",
      "payload_schema": { "type": "object", "properties": { "index": { "type": "integer" } }, "required": ["index"] }
    },
    {
      "action_name": "agent.internal.STAGE_TURN_CONTEXT",
      "summary": "[INTERNAL] Caches the ledger messages while the HKG context is being fetched.",
      "payload_schema": { "type": "object", "properties": { "agentId": { "type": "string" }, "messages": { "type": "array" } }, "required": ["agentId", "messages"] }
    },
    {
      "action_name": "agent.internal.SET_PREVIEW_DATA",
      "summary": "[INTERNAL] Saves the complete preview data.",
      "payload_schema": { "type": "object", "properties": { "agentId": { "type": "string" }, "agnosticRequest": { "type": "object" }, "rawRequestJson": { "type": "string" } }, "required": [ "agentId", "agnosticRequest", "rawRequestJson" ] }
    },
    {
      "action_name": "agent.internal.CONFIRM_DELETE",
      "summary": "[INTERNAL] Dispatched after cleanup side effects are complete.",
      "payload_schema": { "type": "object", "properties": { "agentId": { "type": "string" } }, "required": [ "agentId" ] }
    },
    {
      "action_name": "agent.internal.SET_STATUS",
      "summary": "[INTERNAL] Updates the transient status and optional error message.",
      "payload_schema": { "type": "object", "properties": { "agentId": { "type": "string" }, "status": { "type": "string" }, "error": { "type": [ "string", "null" ] } }, "required": [ "agentId", "status" ] }
    },
    {
      "action_name": "agent.internal.SET_PROCESSING_STEP",
      "summary": "[INTERNAL] Updates the human-readable description of the agent's current processing activity.",
      "payload_schema": { "type": "object", "properties": { "agentId": { "type": "string" }, "step": { "type": [ "string", "null" ] } }, "required": [ "agentId" ] }
    },
    {
      "action_name": "agent.internal.SET_HKG_CONTEXT",
      "summary": "[INTERNAL] Caches the fetched HKG context.",
      "payload_schema": { "type": "object", "properties": { "agentId": { "type": "string" }, "context": { "type": "object" } }, "required": ["agentId", "context"] }
    },
    {
      "action_name": "agent.internal.AVATAR_MOVED",
      "summary": "[INTERNAL] Updates the feature state to reflect that an avatar card has been moved.",
      "payload_schema": { "type": "object", "properties": { "agentId": { "type": "string" }, "sessionId": { "type": "string" }, "messageId": { "type": "string" } }, "required": ["agentId", "sessionId", "messageId"] }
    },
    {
      "action_name": "agent.internal.UPDATE_COGNITIVE_STATE",
      "summary": "[INTERNAL] Updates the persisted cognitive state (NVRAM) of an agent.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": { "type": "string" },
          "state": { "type": "object" }
        },
        "required": ["agentId", "state"]
      }
    }
  ]
}