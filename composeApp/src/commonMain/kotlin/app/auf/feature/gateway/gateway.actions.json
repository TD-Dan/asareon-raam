{
  "feature_name": "gateway",
  "summary": "Acts as a secure, centralized router for all generative AI service requests. It is the single source of truth for available providers and models.",
  "permissions": [
    {
      "key": "gateway:generate",
      "description": "Request AI content generation from providers",
      "dangerLevel": "CAUTION"
    },
    {
      "key": "gateway:preview",
      "description": "Request turn preview / token estimation",
      "dangerLevel": "LOW"
    }
  ],
  "actions": [
    {
      "action_name": "gateway.GENERATE_CONTENT",
      "summary": "Requests content generation from a specific provider.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "providerId": {
            "type": "string"
          },
          "modelName": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "contents": {
            "type": "array",
            "description": "The provider-agnostic prompt content as a list of GatewayMessage objects.",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              },
              "required": [
                "role",
                "content"
              ]
            }
          },
          "systemPrompt": {
            "type": "string"
          }
        },
        "required": [
          "providerId",
          "modelName",
          "correlationId",
          "contents"
        ]
      },
      "required_permissions": [
        "gateway:generate"
      ]
    },
    {
      "action_name": "gateway.PREPARE_PREVIEW",
      "summary": "Requests the compilation of a raw, provider-specific request payload for user preview, without executing the request. If the provider supports token counting, the response will include an estimated input token count.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "providerId": {
            "type": "string"
          },
          "modelName": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "contents": {
            "type": "array",
            "description": "The provider-agnostic prompt content as a list of GatewayMessage objects.",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                }
              },
              "required": [
                "role",
                "content"
              ]
            }
          },
          "systemPrompt": {
            "type": "string"
          }
        },
        "required": [
          "providerId",
          "modelName",
          "correlationId",
          "contents"
        ]
      },
      "required_permissions": [
        "gateway:preview"
      ]
    },
    {
      "action_name": "gateway.REQUEST_AVAILABLE_MODELS",
      "summary": "Requests that the GatewayFeature broadcast the current list of available models.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "required_permissions": []
    },
    {
      "action_name": "gateway.CANCEL_REQUEST",
      "summary": "Cancels an in-flight content generation request identified by its correlation ID.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": "string"
          }
        },
        "required": [
          "correlationId"
        ]
      },
      "required_permissions": [
        "gateway:generate"
      ]
    },
    {
      "action_name": "gateway.CONTENT_GENERATED",
      "summary": "Broadcasts the result of a content generation request.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": "string"
          },
          "rawContent": {
            "type": [
              "string",
              "null"
            ]
          },
          "errorMessage": {
            "type": [
              "string",
              "null"
            ]
          },
          "inputTokens": {
            "type": [
              "integer",
              "null"
            ],
            "description": "The number of input/prompt tokens consumed, as reported by the provider. Null if the provider did not report usage."
          },
          "outputTokens": {
            "type": [
              "integer",
              "null"
            ],
            "description": "The number of output/completion tokens consumed, as reported by the provider. Null if the provider did not report usage."
          }
        },
        "required": [
          "correlationId"
        ]
      }
    },
    {
      "action_name": "gateway.AVAILABLE_MODELS_UPDATED",
      "summary": "Broadcasts the list of currently available providers and their models.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "models": {
            "type": "object",
            "description": "A map where the key is the provider ID and the value is a list of model name strings."
          }
        },
        "required": [
          "models"
        ]
      }
    },
    {
      "action_name": "gateway.MODELS_UPDATED",
      "summary": "[INTERNAL] Dispatched after a provider's model list has been fetched. Used to update the feature's internal state.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "providerId": {
            "type": "string"
          },
          "models": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "providerId",
          "models"
        ]
      }
    },
    {
      "action_name": "gateway.REQUEST_COMPLETED",
      "summary": "[INTERNAL] Dispatched when a generation job completes (success, failure, or cancellation). Used to safely clean up the active job map.",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": "string"
          }
        },
        "required": [
          "correlationId"
        ]
      }
    },
    {
      "action_name": "gateway.RETURN_RESPONSE",
      "summary": "The standard response envelope from the GatewayFeature, containing either generated content or an error, plus optional token usage.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "rawContent": {
            "type": [
              "string",
              "null"
            ]
          },
          "errorMessage": {
            "type": [
              "string",
              "null"
            ]
          },
          "correlationId": {
            "type": "string"
          },
          "inputTokens": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Input/prompt tokens consumed, as reported by the provider."
          },
          "outputTokens": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Output/completion tokens consumed, as reported by the provider."
          }
        },
        "required": [
          "correlationId"
        ]
      }
    },
    {
      "action_name": "gateway.RETURN_PREVIEW",
      "summary": "The response envelope containing the data for a turn preview, plus an optional token count estimate.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": "string"
          },
          "agnosticRequest": {
            "type": "object",
            "description": "The original, provider-agnostic GatewayRequest object."
          },
          "rawRequestJson": {
            "type": "string",
            "description": "The final, provider-specific JSON payload as a formatted string."
          },
          "estimatedInputTokens": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Estimated input token count from the provider's token counting API. Null if the provider does not support pre-flight counting."
          }
        },
        "required": [
          "correlationId",
          "agnosticRequest",
          "rawRequestJson"
        ]
      }
    }
  ]
}