{
  "feature_name": "gateway",
  "summary": "Acts as a secure, centralized router for all generative AI service requests. It is the single source of truth for available providers and models.",
  "listensFor": [
    {
      "action_name": "gateway.GENERATE_CONTENT",
      "summary": "Requests content generation from a specific provider.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "providerId": { "type": "string" },
          "modelName": { "type": "string" },
          "correlationId": { "type": "string" },
          "contents": {
            "type": "array",
            "description": "The provider-agnostic prompt content as a list of GatewayMessage objects.",
            "items": {
              "type": "object",
              "properties": {
                "role": { "type": "string" },
                "content": { "type": "string" }
              },
              "required": ["role", "content"]
            }
          }
        },
        "required": [ "providerId", "modelName", "correlationId", "contents" ]
      }
    },
    {
      "action_name": "gateway.REQUEST_AVAILABLE_MODELS",
      "summary": "Requests that the GatewayFeature broadcast the current list of available models.",
      "payload_schema": null
    }
  ],
  "publishes": [
    {
      "action_name": "gateway.publish.CONTENT_GENERATED",
      "summary": "Broadcasts the result of a content generation request.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": { "type": "string" },
          "rawContent": { "type": ["string", "null"] },
          "errorMessage": { "type": ["string", "null"] }
        },
        "required": ["correlationId"]
      }
    },
    {
      "action_name": "gateway.publish.AVAILABLE_MODELS_UPDATED",
      "summary": "Broadcasts the list of currently available providers and their models.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "models": {
            "type": "object",
            "description": "A map where the key is the provider ID and the value is a list of model name strings."
          }
        },
        "required": ["models"]
      }
    },
    {
      "action_name": "gateway.internal.MODELS_UPDATED",
      "summary": "[INTERNAL] Dispatched after a provider's model list has been fetched. Used to update the feature's internal state.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "providerId": { "type": "string" },
          "models": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["providerId", "models"]
      }
    }
  ],
  "private_envelopes": [
    {
      "type_name": "gateway.response",
      "summary": "The standard response envelope from the GatewayFeature, containing either generated content or an error.",
      "payload_schema": {
        "type": "object",
        "properties": {
          "rawContent": { "type": ["string", "null"] },
          "errorMessage": { "type": ["string", "null"] },
          "correlationId": { "type": "string" }
        },
        "required": ["correlationId"]
      }
    }
  ]
}