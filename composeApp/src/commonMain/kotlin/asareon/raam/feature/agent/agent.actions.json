    {
      "action_name": "agent.REGISTER_PENDING_COMMAND",
      "summary": "[INTERNAL] Records a correlationId \u2192 session mapping when AgentRuntimeFeature dispatches a domain action on behalf of an agent command. Used to route targeted RETURN_* data back to the session via commandbot.DELIVER_TO_SESSION.",
