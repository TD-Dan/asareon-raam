{
  "feature_name": "agent",
  "summary": "Hosts and manages the lifecycle of autonomous, HKG-driven AI agents.",
  "permissions": [
    {
      "key": "agent:manage",
      "description": "Create, delete, and configure agents",
      "dangerLevel": "CAUTION"
    },
    {
      "key": "agent:execute",
      "description": "Initiate and control agent turns",
      "dangerLevel": "CAUTION"
    },
    {
      "key": "agent:cognition",
      "description": "Cognitive self-operations (NVRAM writes, phase transitions). Sandbox-enforced: targets only the caller's own agent unless agent:manage is also held.",
      "dangerLevel": "LOW"
    }
  ],
  "actions": [
    {
      "action_name": "agent.CREATE",
      "summary": "Creates a new agent instance with the specified configuration.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "strategyConfig": {
            "type": "object",
            "description": "Strategy-specific operator configuration (e.g., knowledgeGraphId for Sovereign). Stored as-is; the runtime does not inspect contents."
          },
          "modelProvider": {
            "type": "string"
          },
          "modelName": {
            "type": "string"
          },
          "cognitiveStrategyId": {
            "type": "string",
            "description": "Handle of the cognitive strategy to use (e.g. 'agent.strategy.vanilla')."
          },
          "subscribedSessionIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of session UUIDs this agent observes. UUIDs are immutable and survive session renames."
          },
          "automaticMode": {
            "type": "boolean",
            "default": false
          },
          "autoWaitTimeSeconds": {
            "type": "integer"
          },
          "autoMaxWaitTimeSeconds": {
            "type": "integer"
          },
          "correlationId": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional correlation ID for command-dispatch feedback via agent.ACTION_RESULT.",
            "default": null
          }
        },
        "required": [
          "name"
        ]
      },
      "required_permissions": [
        "agent:manage"
      ]
    },
    {
      "action_name": "agent.CLONE",
      "summary": "Creates a new agent instance by cloning an existing one.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Agent identifier. Accepts UUID, handle, localHandle, or display name."
          },
          "correlationId": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional correlation ID for command-dispatch feedback via agent.ACTION_RESULT.",
            "default": null
          }
        },
        "required": [
          "agentId"
        ]
      },
      "required_permissions": [
        "agent:manage"
      ]
    },
    {
      "action_name": "agent.UPDATE_CONFIG",
      "summary": "Updates the configuration of an existing agent instance. All payload properties are optional.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Agent identifier. Accepts UUID, handle, localHandle, or display name."
          },
          "name": {
            "type": "string"
          },
          "strategyConfig": {
            "type": "object",
            "description": "Strategy-specific operator configuration. Replaces the full object if provided."
          },
          "outputSessionId": {
            "type": [
              "string",
              "null"
            ],
            "description": "Session UUID for the agent's primary output session. Null to clear."
          },
          "modelProvider": {
            "type": "string"
          },
          "modelName": {
            "type": "string"
          },
          "cognitiveStrategyId": {
            "type": "string"
          },
          "subscribedSessionIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of session UUIDs this agent observes."
          },
          "automaticMode": {
            "type": "boolean"
          },
          "autoWaitTimeSeconds": {
            "type": "integer"
          },
          "autoMaxWaitTimeSeconds": {
            "type": "integer"
          },
          "correlationId": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional correlation ID for command-dispatch feedback via agent.ACTION_RESULT.",
            "default": null
          }
        },
        "required": [
          "agentId"
        ]
      },
      "required_permissions": [
        "agent:manage"
      ]
    },
    {
      "action_name": "agent.DELETE",
