    {
      "action_name": "agent.UPDATE_NVRAM",
      "summary": "Updates the agent's cognitive state (NVRAM). Updates are merged into existing state. Self-targeting by default; cross-agent targeting requires agent:manage permission and is rejected with an error if missing.",
      "public": true,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Target agent identifier. Accepts UUID, handle, localHandle, or display name. Optional \u2014 defaults to the calling agent (self-target). Cross-agent targeting requires agent:manage permission; callers with only agent:cognition are rejected with an error if targeting another agent."
          },
          "updates": {
            "type": "object",
            "description": "Key-value pairs to merge into the agent's cognitive state JSON. Keys are validated against the strategy's NVRAM schema."
          },
          "correlationId": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional correlation ID for command-dispatch feedback via agent.ACTION_RESULT.",
            "default": null
          }
        },
        "required": [
          "updates"
        ]
      },
      "required_permissions": [
        "agent:cognition"
      ]
    },
    {
      "action_name": "agent.ACTION_RESULT",
      "summary": "Broadcast notification published after a command-dispatchable agent action completes. Carries a lightweight summary for session feedback via CommandBot. Other observers (logging plugins, usage monitors) may also subscribe.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": [
              "string",
              "null"
            ],
            "description": "From the domain action's payload. Null if not command-originated."
          },
          "requestAction": {
            "type": "string",
            "description": "The domain action name that produced this result, e.g. 'agent.CREATE'."
          },
          "success": {
            "type": "boolean"
          },
          "summary": {
            "type": [
              "string",
              "null"
            ],
            "description": "Human-readable description of what happened."
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "description": "Human-readable error message. Present when success is false."
          }
        },
        "required": [
          "requestAction",
          "success"
        ]
      }
    },
