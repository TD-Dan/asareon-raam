    {
      "action_name": "agent.CONTEXT_UNCOLLAPSE",
      "summary": "Expands a context partition so you can see its full content in your next turn. This is the primary way to browse session workspace files. Use partitionKey format \"sf:{sessionId}:{path}\" with scope \"subtree\" to expand directories. Example: {\"partitionKey\": \"sf:session.my-session:folder/subfolder/\", \"scope\": \"subtree\"}",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Target agent identifier. Accepts UUID, handle, localHandle, or display name. Optional \u2014 defaults to the calling agent (self-target). Cross-agent targeting requires agent:manage permission; callers with only agent:cognition are rejected with an error if targeting another agent."
          },
          "partitionKey": {
            "type": "string",
            "description": "Partition key. Conventions: 'hkg:<holonId>' for a specific holon, 'ws:<relativePath>' for a workspace directory or file (e.g., 'ws:src/', 'ws:src/main.kt'), or a bare partition name (e.g., 'AVAILABLE_ACTIONS')."
          },
          "scope": {
            "type": "string",
            "enum": [
              "full",
              "subtree",
              "single"
            ],
            "default": "single",
            "description": "'single': one item. 'subtree': for HKG holons, reveal children in INDEX; for workspace directories, expand the directory and all nested sub-directories (but not files). 'full': entire partition."
          }
        },
        "required": [
          "partitionKey"
        ]
      },
      "required_permissions": [
        "agent:cognition"
      ]
    },
    {
      "action_name": "agent.CONTEXT_COLLAPSE",
      "summary": "Collapses a context partition so it shows only a summary in the next turn. Use to free up context budget after you are done inspecting a file or directory.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Target agent identifier. Accepts UUID, handle, localHandle, or display name. Optional \u2014 defaults to the calling agent (self-target). Cross-agent targeting requires agent:manage permission; callers with only agent:cognition are rejected with an error if targeting another agent."
          },
          "partitionKey": {
            "type": "string",
            "description": "Partition key. Conventions: 'hkg:<holonId>' for a specific holon, 'ws:<relativePath>' for a workspace directory or file, or a bare partition name."
          }
        },
        "required": [
          "partitionKey"
        ]
      },
      "required_permissions": [
        "agent:cognition"
      ]
