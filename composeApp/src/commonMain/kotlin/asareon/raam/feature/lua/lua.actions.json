{
  "feature_name": "lua",
  "summary": "Embeds a sandboxed Lua scripting runtime, enabling user-authored automation scripts that dispatch actions, subscribe to events, and serve as agent cognitive strategies.",
  "permissions": [
    {
      "key": "lua:execute",
      "description": "Load and run Lua scripts",
      "dangerLevel": "LOW"
    },
    {
      "key": "lua:manage",
      "description": "Create, delete, and modify Lua script files",
      "dangerLevel": "CAUTION"
    },
    {
      "key": "lua:dispatch",
      "description": "Dispatch actions on the bus from within a Lua script",
      "dangerLevel": "CAUTION"
    }
  ],
  "actions": [
    {
      "action_name": "lua.LOAD_SCRIPT",
      "summary": "Load a Lua script from the workspace and register its identity on the bus.",
      "agent_summary": "Load a Lua script from the workspace and register its identity.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptPath": {
            "type": "string",
            "description": "Relative path to the .lua file within the lua workspace.",
            "agent_description": "Relative path to the .lua file in the lua workspace."
          },
          "localHandle": {
            "type": ["string", "null"],
            "description": "Optional explicit local handle for the script identity. Derived from filename if omitted.",
            "agent_description": "Optional local handle. Derived from filename if omitted."
          },
          "autostart": {
            "type": "boolean",
            "description": "If true, script will auto-load on next app startup.",
            "default": false,
            "agent_description": "Auto-load on next app startup."
          }
        },
        "required": ["scriptPath"]
      },
      "required_permissions": ["lua:execute"]
    },
    {
      "action_name": "lua.UNLOAD_SCRIPT",
      "summary": "Unload a running Lua script and unregister its identity.",
      "agent_summary": "Unload a running Lua script and unregister its identity.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string",
            "description": "The full handle of the script identity to unload (e.g., 'lua.my-script').",
            "agent_description": "Script ref to unload (e.g. 'lua.my-script')."
          }
        },
        "required": ["scriptHandle"]
      },
      "required_permissions": ["lua:manage"]
    },
    {
      "action_name": "lua.RELOAD_SCRIPT",
      "summary": "Hot-reload the source code of a running Lua script without changing its identity or subscriptions.",
      "agent_summary": "Hot-reload a script's source. Identity and subscriptions are preserved.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string",
            "description": "The full handle of the script identity to reload.",
            "agent_description": "Script ref to reload."
          }
        },
        "required": ["scriptHandle"]
      },
      "required_permissions": ["lua:execute"]
    },
    {
      "action_name": "lua.EVAL",
      "summary": "Execute a Lua code string in the context of a loaded script (REPL/debugging).",
      "agent_summary": "Eval a Lua snippet in the context of a loaded script (REPL).",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string",
            "description": "The script context to evaluate in.",
            "agent_description": "Script ref to evaluate in."
          },
          "code": {
            "type": "string",
            "description": "Lua source code to evaluate.",
            "agent_description": "Lua source to eval."
          },
          "correlationId": {
            "type": ["string", "null"],
            "default": null,
            "agent_internal": true
          }
        },
        "required": ["scriptHandle", "code"]
      },
      "required_permissions": ["lua:execute"]
    },
    {
      "action_name": "lua.LIST_SCRIPTS",
      "summary": "Query all loaded scripts and their current status.",
      "agent_summary": "List all loaded scripts and their status.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": ["string", "null"],
            "default": null,
            "agent_internal": true
          }
        }
      },
      "required_permissions": ["lua:execute"]
    },
    {
      "action_name": "lua.LIST_STRATEGY_SCRIPT_OPTIONS",
      "summary": "Request the catalog of Lua strategy scripts (those defining on_turn). Used by the Agent Manager to populate the EXTERNAL_REFERENCE selector for agent.strategy.lua.",
      "agent_summary": "List Lua strategy scripts (those defining on_turn).",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {}
      },
      "required_permissions": ["lua:execute"]
    },
    {
      "action_name": "lua.RETURN_STRATEGY_SCRIPT_OPTIONS",
      "summary": "Targeted response to LIST_STRATEGY_SCRIPT_OPTIONS. Conforms to the EXTERNAL_REFERENCE options contract: { options: [{ handle, label, description? }, ...] }.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "handle": { "type": "string" },
                "label": { "type": "string" },
                "description": { "type": ["string", "null"] }
              },
              "required": ["handle", "label"]
            }
          }
        },
        "required": ["options"]
      }
    },
    {
      "action_name": "lua.CREATE_SCRIPT",
      "summary": "Create a new Lua script file in the workspace. If content is omitted the default app-script template is used. displayColor/displayIcon/displayEmoji are optional identity-visual fields applied at identity registration time.",
      "agent_summary": "Create a new Lua script. Default app-script template is used if content is omitted.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name for the new script.",
            "agent_description": "Display name."
          },
          "content": {
            "type": ["string", "null"],
            "description": "Optional initial script content. If absent or null, the default app-script template is used.",
            "agent_description": "Optional initial source. Default template used if omitted."
          },
          "displayColor": {
            "type": ["string", "null"],
            "description": "Optional '#RRGGBB' display color for the script's identity.",
            "agent_description": "Optional '#RRGGBB' color."
          },
          "displayIcon": {
            "type": ["string", "null"],
            "description": "Optional Material icon key for the script's identity.",
            "agent_description": "Optional Material icon key."
          },
          "displayEmoji": {
            "type": ["string", "null"],
            "description": "Optional emoji override for the script's identity.",
            "agent_description": "Optional emoji override."
          }
        },
        "required": ["name"]
      },
      "required_permissions": ["lua:manage"]
    },
    {
      "action_name": "lua.DELETE_SCRIPT",
      "summary": "Delete a Lua script file from disk and unload it if running.",
      "agent_summary": "Delete a Lua script from disk (and unload it if running).",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string",
            "agent_description": "Script ref to delete."
          }
        },
        "required": ["scriptHandle"]
      },
      "required_permissions": ["lua:manage"]
    },
    {
      "action_name": "lua.CLONE_SCRIPT",
      "summary": "Clone an existing Lua script to a new file with a new identity.",
      "agent_summary": "Clone a Lua script (new file, new identity).",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string",
            "description": "The handle of the script to clone.",
            "agent_description": "Script ref to clone."
          },
          "newName": {
            "type": ["string", "null"],
            "description": "Optional name for the clone. Defaults to 'Copy of <original>'.",
            "agent_description": "Optional clone name. Defaults to 'Copy of <original>'."
          }
        },
        "required": ["scriptHandle"]
      },
      "required_permissions": ["lua:manage"]
    },
    {
      "action_name": "lua.RENAME_SCRIPT",
      "summary": "Rename a Lua script (updates display name and file).",
      "agent_summary": "Rename a Lua script (updates display name and file).",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string",
            "agent_description": "Script ref to rename."
          },
          "newName": {
            "type": "string",
            "agent_description": "New display name."
          }
        },
        "required": ["scriptHandle", "newName"]
      },
      "required_permissions": ["lua:manage"]
    },
    {
      "action_name": "lua.TOGGLE_SCRIPT",
      "summary": "Toggle a script between active (running) and inactive (off) states.",
      "agent_summary": "Toggle a script between running and off.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string",
            "agent_description": "Script ref to toggle."
          }
        },
        "required": ["scriptHandle"]
      },
      "required_permissions": ["lua:execute"]
    },
    {
      "action_name": "lua.SAVE_SCRIPT",
      "summary": "Save edited script content to disk and hot-reload if running.",
      "agent_summary": "Save edited script source to disk. Hot-reloads if the script is running.",
      "public": true,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string",
            "agent_description": "Script ref to save."
          },
          "content": {
            "type": "string",
            "description": "The new Lua source code to persist.",
            "agent_description": "New Lua source."
          }
        },
        "required": ["scriptHandle", "content"]
      },
      "required_permissions": ["lua:manage"]
    },
    {
      "action_name": "lua.SCRIPT_LOADED",
      "summary": "Broadcast notification that a Lua script has been successfully loaded and is now running.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string"
          },
          "scriptName": {
            "type": "string"
          },
          "scriptPath": {
            "type": "string"
          }
        },
        "required": ["scriptHandle", "scriptName", "scriptPath"]
      }
    },
    {
      "action_name": "lua.SCRIPT_UNLOADED",
      "summary": "Broadcast notification that a Lua script has been unloaded.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "description": "Why the script was unloaded: 'manual', 'error', 'rate-limit', 'timeout'."
          }
        },
        "required": ["scriptHandle", "reason"]
      }
    },
    {
      "action_name": "lua.SCRIPT_ERROR",
      "summary": "Broadcast notification of a Lua script runtime error.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string"
          },
          "error": {
            "type": "string"
          },
          "context": {
            "type": ["string", "null"],
            "description": "Where the error occurred: 'load', 'callback', 'eval', 'on_turn'."
          }
        },
        "required": ["scriptHandle", "error"]
      }
    },
    {
      "action_name": "lua.SCRIPT_OUTPUT",
      "summary": "Console output from a Lua script (raam.log/warn/error calls).",
      "public": false,
      "broadcast": false,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "scriptHandle": {
            "type": "string"
          },
          "level": {
            "type": "string",
            "description": "'log', 'warn', or 'error'."
          },
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer"
          }
        },
        "required": ["scriptHandle", "level", "message", "timestamp"]
      }
    },
    {
      "action_name": "lua.RETURN_LIST",
      "summary": "Response envelope containing the list of loaded scripts.",
      "public": false,
      "broadcast": false,
      "targeted": true,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": ["string", "null"]
          },
          "scripts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "handle": { "type": "string" },
                "name": { "type": "string" },
                "path": { "type": "string" },
                "status": { "type": "string" },
                "autostart": { "type": "boolean" }
              }
            }
          }
        },
        "required": ["scripts"]
      }
    },
    {
      "action_name": "lua.ACTION_RESULT",
      "summary": "Broadcast result envelope published after a command-dispatchable Lua action completes.",
      "public": false,
      "broadcast": true,
      "targeted": false,
      "payload_schema": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": ["string", "null"]
          },
          "requestAction": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          },
          "summary": {
            "type": ["string", "null"]
          },
          "error": {
            "type": ["string", "null"]
          }
        },
        "required": ["requestAction", "success"]
      }
    }
  ]
}
